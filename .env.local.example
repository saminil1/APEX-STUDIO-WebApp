# ──────────────────────────────────────
# APEX STUDIO - 환경변수 템플릿
# 사용법: 이 파일을 .env 로 복사한 뒤 값을 채워주세요
#   cp .env.local.example .env
# ──────────────────────────────────────

# ── Database (PostgreSQL) ──
# 로컬: postgresql://USER@localhost:5432/apex_studio?schema=public
# 클라우드: AWS RDS / Supabase / Neon 등의 URL 사용
DATABASE_URL="postgresql://USER@localhost:5432/apex_studio?schema=public"
DIRECT_URL="postgresql://USER@localhost:5432/apex_studio?schema=public"

# ── Admin 인증 ──
ADMIN_PASSWORD="your-admin-password"
ADMIN_SESSION_SECRET="your-jwt-secret-key-change-in-production"

# ── EmailJS (서버리스 이메일) ──
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx

# ── Google Analytics ──
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Site URL ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000
