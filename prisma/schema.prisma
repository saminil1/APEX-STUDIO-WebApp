generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl: 클라우드 DB 사용 시 connection pooler 우회용
  // AWS RDS / Google Cloud SQL 직접 연결 시에는 불필요
  // directUrl = env("DIRECT_URL")
}

enum InquiryStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

model Inquiry {
  id               String        @id @default(cuid())
  name             String
  phone            String
  business         String
  message          String        @default("")
  email            String        @default("")
  homepageType     String        @default("") @map("homepage_type")
  homepagePrice    String        @default("") @map("homepage_price")
  additionalOption String        @default("") @map("additional_option")
  additionalPrice  String        @default("") @map("additional_price")
  referenceLink    String        @default("") @map("reference_link")
  fileName         String        @default("") @map("file_name")
  status           InquiryStatus @default(NEW)
  memo             String        @default("")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@map("inquiries")
}
